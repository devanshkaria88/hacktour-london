# LiveKit Cloud — same values as backend/.env
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Must match LIVEKIT_AGENT_NAME in backend/.env
LIVEKIT_AGENT_NAME=olando-checkin

# Speechmatics — used by livekit-plugins-speechmatics for in-conversation captions
SPEECHMATICS_API_KEY=

# Where to send the user audio at session end for biomarker analysis + final transcript
VOICE_SERVICE_URL=http://localhost:8000

# Where to post the finished check-in
BACKEND_URL=http://localhost:3001
VOICE_AGENT_SHARED_SECRET=olando-dev-secret-change-me

# LiveKit Inference models (free with LiveKit Cloud, no extra keys needed)
AGENT_LLM_MODEL=openai/gpt-4o-mini
AGENT_TTS_MODEL=cartesia/sonic-3:9626c31c-bec5-4cca-baa8-f8ba9e84c8bc

LOG_LEVEL=INFO
