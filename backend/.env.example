NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://olando:olando@localhost:5432/olando
DATABASE_SSL=false

VOICE_SERVICE_URL=http://localhost:8000
VOICE_AGENT_SHARED_SECRET=change-me-please

CORS_ORIGIN=http://localhost:3000

# Auth — generate a long random string in production
JWT_SECRET=change-me-please-very-long-random-string
JWT_EXPIRES_IN=7d
SESSION_COOKIE_NAME=olando_session

# LiveKit Cloud — get from https://cloud.livekit.io
# URL looks like wss://your-project-xxxx.livekit.cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Name the worker registers itself as (must match voice-agent/.env)
LIVEKIT_AGENT_NAME=olando-checkin
